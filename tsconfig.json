{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["vitest/globals"]
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "vitest.config.ts", "next.config.ts"],
  "exclude": ["node_modules"]
}
